.page {
  min-height: 100vh;
  background: #F7F8FA;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow-x: hidden;
}
.page-inner {
  width: 100%;
  max-width: 430px;
  display: flex;
  flex-direction: column;
  flex: 1;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ===== 导航栏 ===== */
.nav-bar {
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-title { font-size: 17px; font-weight: 600; }
.nav-placeholder { width: 60px; }

/* ===== 聊天消息区 ===== */
.chat-body {
  flex: 1;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* ===== 文本消息（对齐 Flutter 气泡） ===== */
.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  width: 100%;
}
.msg-row.sent {
  justify-content: flex-end;
}
.msg-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, #22D3EE, #1A6EFF);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 0 2px 6px rgba(34,211,238,0.25);
}
.msg {
  max-width: 80%;
  padding: 10px 14px;
}
.msg.sent {
  background: #1A6EFF;
  color: white;
  border-radius: 14px 0 14px 14px;
  box-shadow: 0 2px 6px rgba(26,110,255,0.2);
}
.msg.received {
  background: white;
  color: #1F2937;
  border-radius: 0 14px 14px 14px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.03);
}

.msg-text { font-size: 14px; line-height: 1.5; display: block; }
.msg-time { font-size: 11px; color: #9CA3AF; display: block; margin-top: 4px; text-align: right; }
.msg.sent .msg-time { color: rgba(255,255,255,0.7); }

.empty-hint {
  text-align: center;
  padding: 40px;
  color: #9CA3AF;
  font-size: 14px;
}

/* ===== 图片消息 ===== */
.msg.image {
  padding: 4px;
  border-radius: 12px;
  overflow: hidden;
  max-width: 180px;
}
.msg-image {
  width: 100%;
  height: 140px;
  border-radius: 8px;
  display: block;
}
.msg.image .msg-time {
  padding: 0 4px;
  margin-top: 2px;
}

/* ===== 语音消息 ===== */
.msg.voice {
  min-width: 90px;
  cursor: pointer;
}
.voice-inner {
  display: flex;
  align-items: center;
  gap: 6px;
}
.voice-icon {
  font-size: 18px;
  line-height: 1;
}
.voice-duration {
  font-size: 15px;
  font-weight: 600;
}
.msg.sent .voice-duration { color: white; }
.msg.received .voice-duration { color: #1F2937; }
.voice-wave {
  display: flex;
  align-items: center;
  gap: 2px;
  height: 16px;
}
.voice-dot {
  display: inline-block;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: currentColor;
  animation: voicePulse 0.8s ease-in-out infinite alternate;
}
.msg.sent .voice-dot { background: rgba(255,255,255,0.8); }
.msg.received .voice-dot { background: #1A6EFF; }
.voice-dot:nth-child(2) { animation-delay: 0.27s; }
.voice-dot:nth-child(3) { animation-delay: 0.54s; }
@keyframes voicePulse {
  0% { opacity: 0.3; transform: scale(0.8); }
  100% { opacity: 1; transform: scale(1.2); }
}

/* ===== 输入区（对齐 Flutter） ===== */
.input-area {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px 30px;
  background: white;
  border-top: 1px solid #EDEDED;
}

/* 附件按钮（话筒-切换语音） */
.input-toggle {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
/* 话筒图标 — 单个 image 标签渲染 */
.toggle-mic-icon {
  width: 22px;
  height: 22px;
  display: block;
}
.toggle-kb-icon {
  font-size: 20px;
  line-height: 1;
}

/* 加号按钮 */
.input-plus {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.plus-icon {
  width: 24px;
  height: 24px;
  display: block;
}

/* 文字输入框 — 圆角药丸 */
.input-box {
  flex: 1;
  height: 38px;
  padding: 0 14px;
  border: 1px solid #EDEDED;
  border-radius: var(--radius-pill, 999px);
  font-size: 14px;
  background: #F7F8FA;
  color: #1F2937;
  transition: border-color 0.2s, background 0.2s;
}
.input-box:focus {
  border-color: #1A6EFF;
  background: white;
}

/* 发送按钮 */
.send-btn {
  min-width: 56px;
  height: 36px;
  padding: 0 14px;
  background: #1A6EFF;
  color: white;
  border-radius: var(--radius-btn, 10px);
  font-size: 14px;
  font-weight: 500;
  line-height: 36px;
  border: none;
  flex-shrink: 0;
}
.send-btn::after { border: none; }

/* 录音按钮 */
.record-btn {
  flex: 1;
  height: 38px;
}
.record-inner {
  height: 100%;
  border-radius: var(--radius-pill, 999px);
  background: #F7F8FA;
  border: 1px solid #EDEDED;
  display: flex;
  align-items: center;
  justify-content: center;
}
.record-inner.recording {
  background: #EFF6FF;
  border-color: #1A6EFF;
}
.record-hint {
  font-size: 14px;
  color: #9CA3AF;
  font-weight: 500;
}
.record-inner.recording .record-hint {
  color: #1A6EFF;
}

/* ===== 操作面板（对齐 Flutter 4 项设计） ===== */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
  z-index: 90;
}
.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F4F4F4;
  border-radius: 0;
  z-index: 100;
  padding: 20px 12px 34px;
  display: flex;
  gap: 0;
  animation: slideUp 0.25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.action-icon-box {
  width: 58px;
  height: 58px;
  border-radius: 14px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}
/* Flutter design colors for 4 action icons */
.action-icon-box.take-photo { background: linear-gradient(135deg, #FBE9E7, #FFF3E0); }
.action-icon-box.photo-album { background: linear-gradient(135deg, #E8F5E9, #F1F8E9); }
.action-icon-box.voice-call { background: linear-gradient(135deg, #E3F2FD, #EDE7F6); }
.action-icon-box.video-call { background: linear-gradient(135deg, #F3E5F5, #EDE7F6); }
.action-label {
  font-size: 12px;
  color: #666;
}
.action-icon-img {
  width: 30px;
  height: 30px;
}
.album-icon-wrap {
  width: 32px;
  height: 32px;
  position: relative;
}
.album-circle {
  position: absolute;
  width: 16.66%;
  height: 16.66%;
  left: 29.17%;
  top: 29.17%;
}
.album-mountain {
  position: absolute;
  width: 62.5%;
  height: 40.3%;
  left: 25%;
  top: 47.2%;
}

/* ===== 系统通知只读提示 ===== */
.system-hint {
  text-align: center;
  padding: 14px 16px;
  background: #F9FAFB;
  border-top: 1px solid #EDEDED;
  color: #9CA3AF;
  font-size: 13px;
}

/* ===== 申请卡片（request 类型消息） ===== */
.request-card-wrap {
  align-self: center !important;
  width: 90%;
  max-width: 300px;
  padding: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  margin: 4px auto;
}
.request-card {
  background: white;
  border-radius: var(--radius-card, 16px);
  padding: 16px;
  border: 1px solid #EDEDED;
  box-shadow: var(--shadow-md, 0 4px 12px rgba(0,0,0,0.03), 0 2px 4px rgba(0,0,0,0.02));
}
.request-card-title {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 6px;
}
.request-card-body {
  display: block;
  font-size: 13px;
  color: #6B7280;
  margin-bottom: 16px;
  line-height: 1.5;
}
.request-card-actions {
  display: flex;
  gap: 10px;
}
.rcard-btn {
  flex: 1;
  height: 38px;
  border-radius: var(--radius-tag, 8px);
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s;
}
.rcard-btn::after { border: none; }
.rcard-btn.approve {
  background: var(--primary, #1A6EFF);
  color: white;
}
.rcard-btn.approve:active { opacity: 0.85; }
.rcard-btn.reject {
  background: #F7F8FA;
  color: #6B7280;
  border: 1px solid #EDEDED;
}
.rcard-btn.reject:active { background: #F3F4F6; }
.request-card-done {
  display: block;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
  color: #6B7280;
  padding: 4px 0;
}
