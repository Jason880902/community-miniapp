.page {
  min-height: 100vh;
  background: #F3F4F6;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.page-inner {
  width: 100%;
  max-width: 430px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

/* ===== 导航栏 ===== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: white;
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-back { display: flex; align-items: center; gap: 4px; }
.nav-back-icon { font-size: 22px; }
.nav-back-text { font-size: 15px; }
.nav-title { font-size: 17px; font-weight: 600; }
.nav-placeholder { width: 60px; }

/* ===== 聊天消息区 ===== */
.chat-body {
  flex: 1;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* ===== 文本消息 ===== */
.msg {
  max-width: 80%;
  padding: 10px 14px;
  border-radius: 16px;
  position: relative;
}
.msg.sent {
  align-self: flex-end;
  background: #1A6EFF;
  color: white;
  border-bottom-right-radius: 4px;
  margin-left: auto;
}
.msg.received {
  align-self: flex-start;
  background: white;
  color: #1F2937;
  border-bottom-left-radius: 4px;
  margin-right: auto;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.msg-text { font-size: 14px; line-height: 1.5; display: block; }
.msg-time { font-size: 11px; color: #9CA3AF; display: block; margin-top: 4px; text-align: right; }
.msg.sent .msg-time { color: rgba(255,255,255,0.7); }

.empty-hint {
  text-align: center;
  padding: 40px;
  color: #9CA3AF;
  font-size: 14px;
}

/* ===== 语音消息 ===== */
.msg.voice {
  padding: 12px 14px;
  min-width: 120px;
}
.voice-inner {
  display: flex;
  align-items: center;
  gap: 8px;
}
.voice-icon {
  font-size: 16px;
  flex-shrink: 0;
}
.msg.received .voice-icon { color: #1A6EFF; }
.msg.sent .voice-icon { color: white; }
.voice-bar {
  flex: 1;
  height: 4px;
  background: rgba(0,0,0,0.1);
  border-radius: 2px;
  overflow: hidden;
}
.msg.sent .voice-bar { background: rgba(255,255,255,0.3); }
.voice-bar-fill {
  height: 100%;
  border-radius: 2px;
  background: currentColor;
  opacity: 0.6;
}
.msg.received .voice-bar-fill { background: #1A6EFF; }
.msg.sent .voice-bar-fill { background: white; }
.voice-dur {
  font-size: 13px;
  font-weight: 500;
  flex-shrink: 0;
}
.msg.received .voice-dur { color: #1F2937; }
.msg.sent .voice-dur { color: white; }

/* 播放状态 */
.msg.voice.playing .voice-icon { color: #22D3EE; }
.msg.voice.playing .voice-bar-fill {
  animation: voicePlay 0.8s ease infinite alternate;
}
@keyframes voicePlay {
  from { opacity: 0.3; }
  to { opacity: 1; }
}

/* ===== 图片消息 ===== */
.msg.image {
  padding: 4px;
  border-radius: 12px;
  overflow: hidden;
  max-width: 180px;
}
.msg-image {
  width: 100%;
  height: 140px;
  border-radius: 8px;
  display: block;
}
.msg.image .msg-time {
  padding: 0 4px;
  margin-top: 2px;
}

/* ===== 通话记录（居中系统消息） ===== */
.msg.call-center {
  align-self: center;
  background: transparent;
  padding: 4px 12px;
  box-shadow: none;
  max-width: none;
}
.call-log {
  font-size: 12px;
  color: #9CA3AF;
  background: rgba(0,0,0,0.05);
  padding: 4px 12px;
  border-radius: 8px;
}

/* ===== 输入区 ===== */
.input-area {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 12px;
  background: white;
  border-top: 1px solid #EDEDED;
  padding-bottom: calc(10px + env(safe-area-inset-bottom));
}

/* 模式切换 */
.input-toggle {
  width: 38px;
  height: 38px;
  border-radius: 8px;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.toggle-icon { font-size: 18px; }

/* 文字输入框 */
.input-box {
  flex: 1;
  height: 38px;
  padding: 0 12px;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  background: #F3F4F6;
  color: #1F2937;
}

/* 录音按钮 */
.record-btn {
  flex: 1;
  height: 38px;
}
.record-inner {
  height: 100%;
  border-radius: 8px;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
}
.record-inner.recording {
  background: #EFF6FF;
  border: 1px solid #1A6EFF;
}
.record-hint {
  font-size: 14px;
  color: #6B7280;
}
.recording .record-hint {
  color: #1A6EFF;
  font-weight: 500;
}

/* 加号按钮 */
.input-plus {
  width: 38px;
  height: 38px;
  border-radius: 8px;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.plus-icon {
  font-size: 22px;
  color: #6B7280;
  line-height: 1;
}

/* 发送按钮 */
.send-btn {
  height: 38px;
  padding: 0 18px;
  background: #1A6EFF;
  color: white;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  line-height: 38px;
  border: none;
  flex-shrink: 0;
}
.send-btn::after { border: none; }

/* ===== 操作面板 ===== */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
  z-index: 90;
}
.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: white;
  border-radius: 16px 16px 0 0;
  z-index: 100;
  padding: 24px 16px calc(16px + env(safe-area-inset-bottom));
  display: flex;
  gap: 16px;
  animation: slideUp 0.25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.action-icon-box {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}
.action-icon-box.camera { background: #EFF6FF; }
.action-icon-box.call { background: #ECFDF5; }
.action-icon-box.video { background: #FAF5FF; }
.action-label {
  font-size: 13px;
  color: #6B7280;
}

/* ===== 通话界面 ===== */
.call-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}
.call-card {
  width: 260px;
  background: white;
  border-radius: 20px;
  padding: 36px 24px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.call-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: #1A6EFF;
  color: white;
  font-size: 28px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}
.call-name {
  font-size: 18px;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 4px;
}
.call-type-label {
  font-size: 13px;
  color: #6B7280;
  margin-bottom: 2px;
}
.call-status-text {
  font-size: 13px;
  color: #9CA3AF;
  margin-bottom: 28px;
}
.call-btn-row {
  display: flex;
  gap: 24px;
}
.call-btn {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  color: white;
}
.call-btn.decline { background: #EF4444; }
.call-btn.accept { background: #22C55E; }
.call-btn.hangup { background: #EF4444; }
