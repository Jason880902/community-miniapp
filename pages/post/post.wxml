<view class="page">
  <view class="page-inner">
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-back-icon">{{icons.close}}</text>
    </view>
    <text class="nav-title">发布物品</text>
    <view class="nav-placeholder"></view>
  </view>

  <scroll-view class="body" scroll-y>
    <!-- 图片上传 -->
    <view class="form-group">
      <text class="form-label">物品照片</text>
      <view class="image-grid">
        <view class="image-item" wx:for="{{images}}" wx:key="index">
          <image class="image-preview" src="{{item}}" mode="aspectFill" />
          <view class="image-delete" data-index="{{index}}" bindtap="removeImage">{{icons.close}}</view>
        </view>
        <view wx:if="{{images.length < maxImages}}" class="image-uploader" bindtap="chooseImage">
          <text class="upload-icon">+</text>
          <text class="upload-text">拍照/上传</text>
        </view>
      </view>
    </view>

    <!-- AI 识别 -->
    <view class="ai-section" wx:if="{{images.length > 0}}">
      <button class="ai-btn" bindtap="aiClassify" disabled="{{aiLoading}}">
        <text class="ai-btn-text">{{aiLoading ? 'AI识别中...' : 'AI 智能识别'}}</text>
        <text wx:if="{{!aiLoading}}" class="ai-btn-arrow">{{icons.arrow}}</text>
      </button>
      <view wx:if="{{aiResult}}" class="ai-result">
        <text class="ai-result-label">识别结果：</text>
        <text class="ai-result-cat">{{aiResult.category}}</text>
        <text class="ai-result-conf">{{aiResult.confidence}}</text>
        <text class="ai-result-hint">如不准确可手动修改下方信息</text>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">物品名称 <text class="required">*</text></text>
      <input class="form-input" placeholder="如：实木书桌" maxlength="50" bindinput="onField" data-field="title" value="{{formData.title}}" />
    </view>

    <view class="form-group">
      <text class="form-label">类别 <text class="required">*</text></text>
      <picker class="form-picker" mode="selector" range="{{categories}}" bindchange="onCategoryChange">
        <view class="picker-value">{{formData.category || '请选择类别'}}</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">成色 <text class="required">*</text></text>
      <view class="condition-list">
        <view class="condition-item {{formData.condition === c ? 'active' : ''}}" wx:for="{{conditions}}" wx:key="*this" data-condition="{{item}}" bindtap="selectCondition">{{item}}</view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">物品描述</text>
      <textarea class="form-textarea" placeholder="描述物品的使用情况、尺寸等" bindinput="onField" data-field="desc" value="{{formData.desc}}" />
    </view>

    <view class="form-group">
      <text class="form-label">所在楼栋</text>
      <input class="form-input" placeholder="如：3号楼2单元" maxlength="20" bindinput="onField" data-field="location" value="{{formData.location}}" />
    </view>

    <button class="submit-btn" bindtap="submitPost" disabled="{{!canSubmit}}">发布物品</button>
  </scroll-view>
  </view>
</view>
