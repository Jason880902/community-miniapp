.page {
  min-height: 100vh;
  background: #F5F6FA;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow-x: hidden;
}

.login-body {
  width: 100%;
  max-width: 320px;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  align-items: center;
  padding: 40px 24px;
}

/* ===== Logo 艺术字 ===== */
.logo-area {
  text-align: center;
  margin-bottom: 48px;
}
.logo {
  font-size: 44px;
  font-weight: 900;
  letter-spacing: 6px;
  background: linear-gradient(135deg, #1A6EFF 0%, #4F46E5 50%, #7C3AED 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 2px 8px rgba(26, 110, 255, 0.15);
}
.subtitle {
  font-size: 14px;
  color: #6B7280;
  letter-spacing: 3px;
  margin-top: 10px;
  display: block;
  font-weight: 400;
}

/* ===== 用户信息预览 ===== */
.user-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24px;
}
.user-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin-bottom: 8px;
}
.user-name {
  font-size: 16px;
  font-weight: 600;
  color: #1F2937;
}

/* ===== 用户协议勾选 ===== */
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  margin-bottom: 20px;
  flex-wrap: wrap;
  width: 100%;
}
.agreement-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
.checkbox {
  width: 20px;
  height: 20px;
  border-radius: var(--radius-tag, 6px);
  border: 2px solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  transition: all 0.2s;
}
.checkbox.checked {
  background: #1A6EFF;
  border-color: #1A6EFF;
}
.checkmark {
  font-size: 12px;
  color: white;
  font-weight: 700;
  line-height: 1;
}
.agreement-text {
  font-size: 13px;
  color: #6B7280;
  line-height: 16px;
}
.agreement-link {
  font-size: 13px;
  color: #1A6EFF;
  line-height: 16px;
}

/* ===== 授权按钮 ===== */
.auth-btn {
  width: 100%;
  max-width: 326px;
  height: 52px;
  border-radius: var(--radius-btn, 10px);
  background: #1A6EFF;
  color: white;
  font-size: 17px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: var(--shadow-btn, 0 4px 12px rgba(26,110,255,0.33));
}
.auth-btn:active { opacity: 0.85; transform: scale(0.98); box-shadow: 0 2px 6px rgba(26,110,255,0.25); }
.auth-btn[disabled] { background: #93B8FF; color: white; box-shadow: none; }
.auth-btn::after { border: none; }

/* ===== 手机号授权弹窗 ===== */
.phone-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: white;
  border-radius: 20px 20px 0 0;
  z-index: 100;
  padding: 16px 24px calc(24px + env(safe-area-inset-bottom));
  animation: slideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -4px 32px rgba(0,0,0,0.08);
  text-align: center;
}
.sheet-desc {
  font-size: 13px;
  color: #9CA3AF;
  margin-bottom: 20px;
  display: block;
}
.phone-auth-btn {
  width: 100%;
  height: 50px;
  border-radius: 10px;
  background: #1A6EFF;
  color: white;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 14px;
  box-shadow: 0 4px 14px rgba(26,110,255,0.35);
}
.phone-auth-btn:active { opacity: 0.85; }
.phone-auth-btn::after { border: none; }
.phone-skip {
  font-size: 13px;
  color: #9CA3AF;
  padding: 8px;
  display: block;
}
.phone-divider {
  display: flex;
  align-items: center;
  margin: 12px 0;
}
.phone-divider::before, .phone-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #EDEDED;
}
.phone-divider text {
  font-size: 12px;
  color: #9CA3AF;
  margin: 0 10px;
}
.phone-display {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  background: #ECFDF5;
  border-radius: 8px;
}
.phone-display-label { font-size: 12px; color: #6B7280; }
.phone-display-value { font-size: 14px; color: #1F2937; font-weight: 600; flex: 1; text-align: left; }
.phone-display-badge { font-size: 11px; color: #10B981; background: white; padding: 2px 8px; border-radius: 4px; font-weight: 500; }

/* ===== 小区选择弹窗 ===== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 90;
  animation: fadeIn 0.25s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.community-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: white;
  border-radius: 20px 20px 0 0;
  z-index: 100;
  padding: 16px 24px calc(24px + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -4px 32px rgba(0,0,0,0.08);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.sheet-handle {
  width: 36px;
  height: 4px;
  background: #E5E7EB;
  border-radius: 2px;
  margin: 0 auto 16px;
}

.sheet-title {
  display: block;
  font-size: 18px;
  font-weight: 700;
  color: #1F2937;
  text-align: center;
  margin-bottom: 20px;
}

/* 快捷操作 */
.sheet-actions { margin-bottom: 16px; }
.sheet-action {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: #F9FAFB;
  border-radius: 14px;
  margin-bottom: 10px;
  border: 1.5px solid transparent;
  transition: all 0.2s;
}
.sheet-action:active { background: #EFF6FF; border-color: #BFDBFE; }
.action-icon { font-size: 22px; flex-shrink: 0; }
.action-text { flex: 1; display: flex; flex-direction: column; }
.action-label { font-size: 15px; font-weight: 600; color: #1F2937; }
.action-desc { font-size: 12px; color: #6B7280; margin-top: 2px; }
.action-arrow { font-size: 18px; color: #9CA3AF; }
.action-loading { font-size: 12px; color: #1A6EFF; font-weight: 500; }

/* 分割线 */
.sheet-divider {
  display: flex;
  align-items: center;
  margin: 16px 0;
}
.sheet-divider::before,
.sheet-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #EDEDED;
}
.divider-text {
  font-size: 12px;
  color: #9CA3AF;
  margin: 0 12px;
}

/* 搜索 */
.sheet-search { margin-bottom: 8px; }
.sheet-input {
  width: 100%;
  height: 46px;
  border: 2px solid #E5E7EB;
  border-radius: 12px;
  padding: 0 14px;
  font-size: 15px;
  box-sizing: border-box;
  color: #1F2937;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.sheet-input:focus {
  border-color: #1A6EFF;
  box-shadow: 0 0 0 4px rgba(26,110,255,0.08);
}

/* 小区列表 */
.sheet-suggest {
  max-height: 180px;
  overflow-y: auto;
  margin-bottom: 12px;
  border: 1.5px solid #EDEDED;
  border-radius: 12px;
  overflow: hidden;
}
.suggest-item {
  padding: 13px 14px;
  font-size: 14px;
  color: #1F2937;
  border-bottom: 1px solid #F3F4F6;
  transition: background 0.15s;
}
.suggest-item:last-child { border-bottom: none; }
.suggest-item:active { background: #EFF6FF; }
.suggest-item.selected {
  background: #EFF6FF;
  color: #1A6EFF;
  font-weight: 600;
}

.contact-fields {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 14px;
}
.contact-fields .sheet-input {
  margin-bottom: 0;
}
.phone-btn {
  width: 100%;
  height: 48px;
  border-radius: 10px;
  background: #1A6EFF;
  color: white;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s;
}
.phone-btn:active { opacity: 0.85; }
.phone-btn.authed { background: #10B981; }
.phone-btn::after { border: none; }

.confirm-btn {
  width: 100%;
  height: 50px;
  border-radius: var(--radius-pill, 999px);
  background: #1A6EFF;
  color: white;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 14px;
  box-shadow: 0 4px 14px rgba(26,110,255,0.35);
  transition: all 0.2s;
}
.confirm-btn:active { opacity: 0.9; transform: scale(0.98); box-shadow: 0 2px 8px rgba(26,110,255,0.25); }
.confirm-btn[disabled] { background: #D1D5DB; color: white; box-shadow: none; }
.confirm-btn::after { border: none; }
