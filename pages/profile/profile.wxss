.page {
  min-height: 100vh;
  background: #EDF4FF;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.page-inner {
  width: 100%;
  max-width: 430px;
  flex: 1;
  padding-bottom: 70px;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 16px;
  background: white;
}
.nav-title { font-size: 17px; font-weight: 600; }

.profile-card {
  background: white;
  padding: 24px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  border-bottom: 1px solid var(--border, #E5E7EB);
}
.profile-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: var(--primary, #1A6EFF);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  font-weight: 700;
}
.profile-info { flex: 1; }
.profile-name { font-size: 20px; font-weight: 700; display: block; color: #1F2937; }
.profile-community { font-size: 14px; color: var(--text-secondary, #6B7280); display: block; margin-top: 2px; }

.stats-card {
  display: flex;
  background: white;
  padding: 16px 0;
  margin-bottom: 12px;
}
.stat-item { flex: 1; text-align: center; border-right: 1px solid var(--border, #E5E7EB); }
.stat-item:last-child { border-right: none; }
.stat-num { font-size: 22px; font-weight: 700; color: var(--primary, #1A6EFF); display: block; }
.stat-label { font-size: 12px; color: var(--text-secondary, #6B7280); display: block; margin-top: 2px; }

.menu-list { background: white; }
.menu-item {
  display: flex;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border, #E5E7EB);
}
.menu-item:last-child { border-bottom: none; }
.menu-text { flex: 1; font-size: 15px; color: #1F2937; }
.menu-arrow { font-size: 20px; color: var(--text-light, #9CA3AF); }

/* ===== 底部标签栏 ===== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  background: white;
  border-top: 1px solid #EDEDED;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-inner {
  width: 100%;
  max-width: 430px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: 2px;
  padding: 0 8px;
  box-sizing: border-box;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9CA3AF;
  position: relative;
  height: 50px;
  border-radius: 12px;
  gap: 1px;
  transition: all 0.2s;
}
.tab-item.active {
  color: white;
  background: #1A6EFF;
}
.tab-post {
  background: #1A6EFF;
  color: white;
}
.tab-item.active .tab-icon,
.tab-post .tab-icon { color: white; }
.tab-icon { font-size: 16px; line-height: 1.2; }
.tab-label { font-size: 10px; font-weight: 500; line-height: 1.2; }
.tab-badge {
  position: absolute;
  top: 0;
  right: 50%;
  margin-right: -20px;
  background: #EF4444;
  color: white;
  font-size: 8px;
  padding: 1px 4px;
  border-radius: 8px;
  min-width: 14px;
  text-align: center;
  line-height: 1.2;
}
