.page {
  min-height: 100vh;
  background: #F5F6FA;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow-x: hidden;
}
.page-inner {
  width: 100%;
  max-width: 430px;
  flex: 1;
  padding-bottom: 70px;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ===== 头部（与首页一致） ===== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px 10px;
  background: white;
  border-bottom: 1px solid #EDEDED;
}
.header-left { display: flex; flex-direction: column; }
.header-title { font-size: 24px; font-weight: 700; color: #1A6EFF; letter-spacing: -0.5px; }
.header-location { font-size: 12px; color: #6B7280; margin-top: 2px; }
.header-right { display: flex; align-items: center; gap: 10px; }
.header-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A6EFF, #4F46E5);
  color: white;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 用户信息头部（蓝色渐变） ===== */
.profile-header {
  background: linear-gradient(135deg, #1A6EFF 0%, #4F46E5 100%);
  padding: 32px 20px 32px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
.profile-avatar-wrap {
  position: relative;
  width: 72px;
  height: 72px;
}
.profile-avatar-img {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  border: 3px solid rgba(255,255,255,0.9);
  object-fit: cover;
}
.profile-avatar-text {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  border: 3px solid rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.13);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 700;
}
.profile-avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.15);
}
.profile-header .profile-name {
  font-size: 20px;
  font-weight: 700;
  color: white;
}
.profile-header .profile-community {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
}

/* ===== 用户信息卡片（旧版，保留兼容） ===== */
.profile-card {
  background: white;
  padding: 28px 24px;
  display: flex;
  align-items: center;
  gap: 18px;
}
.profile-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A6EFF, #4F46E5);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 700;
  box-shadow: 0 4px 12px rgba(26,110,255,0.25);
}
.profile-info { flex: 1; }
.profile-name { font-size: 22px; font-weight: 700; display: block; color: #1F2937; }
.profile-community { font-size: 14px; color: #6B7280; display: block; margin-top: 3px; }

/* ===== 统计卡片 ===== */
.stats-card {
  display: flex;
  background: white;
  height: 72px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.02);
}
.stat-item { flex: 1; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; border-right: 1px solid #EDEDED; }
.stat-item:last-child { border-right: none; }
.stat-num { font-size: 22px; font-weight: 700; color: #1A6EFF; display: block; line-height: 1; }
.stat-num.green { color: var(--success, #10B981); }
.stat-num.amber { color: var(--warning, #F59E0B); }
.stat-label { font-size: 12px; color: #6B7280; display: block; }

/* ===== 联系方式卡片 ===== */
.contact-card {
  background: white;
  margin: 12px 0 12px;
  padding: 14px 16px;
}
.contact-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.contact-title { font-size: 14px; font-weight: 600; color: #1F2937; }
.contact-edit { font-size: 13px; color: #1A6EFF; cursor: pointer; }
.contact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-top: 1px solid #F3F4F6;
}
.contact-label { font-size: 13px; color: #6B7280; }
.contact-value { font-size: 13px; color: #1F2937; font-weight: 500; }
.contact-phone-btn {
  height: 30px;
  line-height: 30px;
  padding: 0 12px;
  border-radius: 6px;
  background: #1A6EFF;
  color: white;
  font-size: 12px;
  font-weight: 600;
  border: none;
}
.contact-phone-btn:active { opacity: 0.85; }
.contact-phone-btn::after { border: none; }

/* ===== 菜单列表 ===== */
.menu-list {
  background: white;
  border-radius: var(--radius-card, 16px);
  margin: 0 0 12px;
  box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.04));
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #F9FAFB;
  gap: 12px;
  transition: background 0.15s;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #F9FAFB; }
.menu-item.danger .menu-text { color: #6B7280; }
.menu-icon-wrap {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.menu-icon-blue { background: #EFF6FF; }
.menu-icon-green { background: #ECFDF5; }
.menu-icon-amber { background: #FFF7ED; }
.menu-icon-red { background: #FEF2F2; }
.menu-icon-gray { background: #F3F4F6; }
.menu-text { flex: 1; font-size: 15px; color: #1F2937; font-weight: 500; }
.menu-arrow { width: 18px; height: 18px; flex-shrink: 0; }
.menu-badge { margin-left: auto; margin-right: 4px; min-width: 18px; height: 18px; line-height: 18px; border-radius: 9px; background: #ee0a24; color: #fff; font-size: 11px; text-align: center; padding: 0 5px; }
/* ===== section 标题行 ===== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 48px;
  padding: 0 0 14px;
}
.section-count { font-size: 13px; color: #9CA3AF; }

/* ===== 物品列表（继承） ===== */
.items-section {
  background: white;
  border-radius: var(--radius-card, 16px);
  margin: 0 0 12px;
  padding: 20px;
  box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.04));
}
.items-section-title { font-size: 15px; font-weight: 700; color: #1F2937; }
.my-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 0;
  border-top: 1px solid #F3F4F6;
}
.my-item:first-of-type { border-top: none; }
.my-item-img {
  width: 56px; height: 56px; border-radius: 12px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 600;
  box-shadow: var(--shadow-sm, 0 1px 2px rgba(0,0,0,0.06));
  object-fit: cover;
}
.my-item-info { flex: 1; min-width: 0; }
.my-item-title { font-size: 14px; font-weight: 600; color: #1F2937; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.my-item-tags { display: flex; gap: 4px; margin: 5px 0; flex-wrap: wrap; }
.my-item-time { font-size: 11px; color: #9CA3AF; display: block; }
.my-item-actions { display: flex; flex-direction: column; gap: 6px; flex-shrink: 0; }
.my-item-btn {
  height: 28px; line-height: 28px; padding: 0 10px;
  border-radius: var(--radius-tag, 6px); font-size: 11px; font-weight: 500;
  transition: all 0.2s; border: none;
  display: flex; align-items: center; justify-content: center;
}
.my-item-btn.claim { background: #1A6EFF; color: white; box-shadow: 0 2px 6px rgba(26,110,255,0.2); }
.my-item-btn.claim:active { opacity: 0.85; }
.my-item-btn.unlist { background: #F3F4F6; color: #6B7280; }
.my-item-btn.unlist:active { background: #E5E7EB; }
.my-item-btn.edit { background: #EFF6FF; color: #1A6EFF; }
.my-item-btn.edit:active { background: #DBEAFE; }
.my-item-btn.republish { background: #F0FDF4; color: #16A34A; }
.my-item-btn.republish:active { background: #DCFCE7; }
.my-item-btn.mark { background: #EFF6FF; color: #1A6EFF; }
.my-item-btn.disabled { background: #F3F4F6; color: #9CA3AF; }
.my-item-btn::after { border: none; }

.menu-icon-img { width: 18px; height: 18px; display: block; }
.menu-icon-purple { background: #FAF5FF; }

/* Tab Bar 见 app.wxss（Flutter pill 设计） */