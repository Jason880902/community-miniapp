.page {
  min-height: 100vh;
  background: #F5F6FA;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow-x: hidden;
}
.page-inner {
  width: 100%;
  max-width: 430px;
  display: flex;
  flex-direction: column;
  flex: 1;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ===== 详情分区（Flutter 灰度分隔） ===== */
.detail-section-title {
  background: white;
  padding: 16px 16px 12px;
}

.detail-section-meta {
  height: 60px;
  background: white;
  display: flex;
  align-items: center;
}
.meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 16px;
  gap: 4px;
  height: 60px;
}
.meta-divider {
  width: 1px;
  height: 32px;
  background: #EDEDED;
  flex-shrink: 0;
}
.meta-label { font-size: 12px; color: #9CA3AF; font-weight: 500; letter-spacing: 0.2px; }
.meta-value { font-size: 14px; font-weight: 500; color: #1F2937; }

.detail-section-owner {
  background: white;
  height: 76px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.detail-section-desc {
  background: white;
  padding: 16px;
}
.desc-label {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 8px;
}
.detail-desc {
  font-size: 14px;
  line-height: 1.6;
  color: #6B7280;
  display: block;
}

/* ===== 导航栏 ===== */
.nav-bar {
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-title { font-size: 16px; font-weight: 600; color: #1F2937; }
.nav-placeholder { width: 60px; }

.body {
  flex: 1;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

.detail-image-wrap {
  position: relative;
  width: 100%;
  height: 260px;
  overflow: hidden;
}
.detail-swiper {
  width: 100%;
  height: 100%;
}
.detail-image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-image-placeholder {
  width: 100%;
  height: 260px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.image-counter-wrap {
  position: absolute;
  bottom: 14px;
  right: 14px;
}
.image-counter {
  background: rgba(0,0,0,0.52);
  color: white;
  font-size: 12px;
  font-weight: 500;
  padding: 4px 12px;
  border-radius: 999px;
  line-height: 1.4;
}
.detail-cat-label {
  font-size: 22px;
  font-weight: 600;
  letter-spacing: 2px;
}

.title-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
.detail-title { font-size: 18px; font-weight: 700; color: #1F2937; line-height: 1.3; flex: 1; }
.detail-time { font-size: 12px; color: #9CA3AF; flex-shrink: 0; padding-top: 4px; }
.detail-tags { display: flex; gap: 6px; margin-top: 10px; align-items: center; flex-wrap: wrap; }
.detail-tag {
  font-size: 11px;
  padding: 4px 10px;
  border-radius: var(--radius-tag, 6px);
  font-weight: 500;
  display: inline-flex;
  align-items: center;
}
.detail-tag.category { background: #EFF6FF; color: var(--primary, #1A6EFF); }
.detail-tag.condition { background: #ECFDF5; color: var(--success, #10B981); }
.detail-tag.status { background: #ECFDF5; color: var(--success, #10B981); }

.owner-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  flex-shrink: 0;
  object-fit: cover;
}
.owner-avatar.img { display: block; }
.owner-avatar.text {
  background: linear-gradient(135deg, #1A6EFF, #4F46E5);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  font-weight: 700;
  box-shadow: 0 2px 8px rgba(26,110,255,0.2);
}
.owner-info { flex: 1; }
.owner-name { font-size: 15px; font-weight: 600; display: block; color: #1F2937; }
.owner-community { font-size: 12px; color: #9CA3AF; display: block; margin-top: 3px; }
.owner-stats {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 8px 14px;
  background: #F0FDF4;
  border-radius: 12px;
}
.owner-stats-num { font-size: 20px; font-weight: 800; color: #10B981; line-height: 1.1; }
.owner-stats-label { font-size: 11px; color: #6B7280; }

/* ===== 8px 灰色分割区（对齐 Flutter） ===== */
.section-gap {
  height: 8px;
  background: #F7F8FA;
}

/* ===== 物主联系方式 ===== */
.detail-section-contact {
  background: white;
  padding: 4px 16px;
}
.detail-section-contact .contact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #F3F4F6;
}
.detail-section-contact .contact-row:last-child { border-bottom: none; }
.detail-section-contact .contact-label { font-size: 13px; color: #6B7280; }
.detail-section-contact .contact-value { font-size: 14px; color: #1F2937; font-weight: 500; }

/* ===== 详情标签（Flutter 风格） ===== */
.detail-tag-chip {
  height: 24px;
  line-height: 24px;
  padding: 0 10px;
  border-radius: var(--radius-tag, 6px);
  font-size: 11px;
  font-weight: 500;
}

/* ===== 申请列表 ===== */
.request-section {
  background: white;
  border-radius: var(--radius-card, 16px);
  padding: 16px;
  margin: 8px 16px 12px;
  box-shadow: var(--shadow-md, 0 4px 12px rgba(0,0,0,0.03), 0 2px 4px rgba(0,0,0,0.02));
  border: 1px solid #EFF6FF;
}
.request-section-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #EDEDED;
}
.request-section-title { font-size: 15px; font-weight: 600; color: #1F2937; }
.request-count-badge {
  background: #1A6EFF;
  color: white;
  font-size: 11px;
  font-weight: 700;
  min-width: 20px;
  height: 20px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
}
.request-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-top: 1px solid #F3F4F6;
}
.request-item:first-of-type { border-top: none; }
.request-user { display: flex; align-items: center; gap: 12px; flex: 1; }
.request-avatar {
  width: 40px; height: 40px; border-radius: 50%;
  background: linear-gradient(135deg, #22D3EE, #1A6EFF);
  background-size: cover; background-position: center;
  flex-shrink: 0;
}
.request-avatar.text-avatar {
  display: flex; align-items: center; justify-content: center;
  color: white;
  font-size: 14px; font-weight: 600;
}
.request-info { display: flex; flex-direction: column; gap: 3px; }
.request-name { font-size: 14px; font-weight: 600; color: #1F2937; }
.request-time { font-size: 12px; color: #9CA3AF; }
.request-actions { display: flex; gap: 8px; flex-shrink: 0; }
.request-btn {
  height: 34px; line-height: 34px; padding: 0 16px;
  border-radius: var(--radius-btn, 10px); font-size: 13px; font-weight: 600;
  transition: all 0.2s; border: none;
}
.request-btn.approve { background: #1A6EFF; color: white; box-shadow: 0 2px 8px rgba(26,110,255,0.25); }
.request-btn.approve:active { opacity: 0.85; transform: scale(0.97); }
.request-btn.reject { background: #F3F4F6; color: #6B7280; }
.request-btn.reject:active { background: #E5E7EB; }
.request-btn::after { border: none; }

/* ===== 相似物品（横向滚动） ===== */
.similar-section {
  background: white;
  padding: 16px;
}
.similar-section-title {
  font-size: 15px;
  font-weight: 700;
  color: #1F2937;
  display: block;
  margin-bottom: 12px;
}
.similar-scroll {
  display: flex;
  flex-direction: row;
  overflow-x: auto;
  white-space: nowrap;
  scrollbar-width: none;
  padding-bottom: 4px;
}
.similar-scroll::-webkit-scrollbar { display: none; }
.similar-item {
  display: inline-flex;
  flex-direction: column;
  width: 130px;
  flex-shrink: 0;
  margin-right: 12px;
  border-radius: 12px;
  overflow: hidden;
  background: #F9FAFB;
}
.similar-image {
  width: 130px;
  height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.similar-placeholder { display: flex; align-items: center; justify-content: center; }
.similar-cat { font-size: 16px; font-weight: 600; opacity: 0.8; }
.similar-info { padding: 8px 10px 10px; }
.similar-title {
  font-size: 13px;
  font-weight: 600;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  max-width: 110px;
}
.similar-meta {
  font-size: 11px;
  color: #9CA3AF;
  margin-top: 4px;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 底部操作按钮（Flutter 83h 设计） ===== */
.detail-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  height: 83px;
  padding: 0 16px;
  background: white;
  border-top: 1px solid var(--border, #EDEDED);
  box-sizing: border-box;
}
.action-btn {
  height: 48px;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  border: none;
}
.action-btn.primary {
  flex: 2;
  background: var(--primary, #1A6EFF);
  color: white;
  box-shadow: 0 4px 12px rgba(26,110,255,0.27);
}
.action-btn.primary:active { opacity: 0.85; transform: scale(0.98); }
.action-btn.secondary {
  flex: 1;
  background: #F7F8FA;
  color: #6B7280;
  border: 1px solid #EDEDED;
}
.action-btn.secondary:active { background: #F3F4F6; }
.action-btn.disabled {
  flex: 2;
  background: #F3F4F6;
  color: #9CA3AF;
}