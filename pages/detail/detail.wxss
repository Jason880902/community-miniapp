.page {
  min-height: 100vh;
  background: #F7F8FA;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.page-inner {
  width: 100%;
  max-width: 430px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

/* ===== 导航栏 ===== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: white;
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-back { display: flex; align-items: center; gap: 4px; }
.nav-back-icon { font-size: 20px; }
.nav-back-text { font-size: 14px; }
.nav-title { font-size: 16px; font-weight: 600; color: #1F2937; }
.nav-placeholder { width: 60px; }

.body {
  flex: 1;
  padding: 12px 16px;
}

.detail-image {
  width: 100%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  margin-bottom: 12px;
  overflow: hidden;
}
.detail-cat-label {
  font-size: 22px;
  font-weight: 600;
  letter-spacing: 2px;
}

.detail-card {
  background: white;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 12px;
}
.detail-title { font-size: 18px; font-weight: 700; display: block; margin-bottom: 10px; color: #1F2937; }
.detail-tags { display: flex; gap: 6px; margin-bottom: 14px; }

.detail-meta {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  padding: 12px 0;
  border-top: 1px solid #EDEDED;
  margin-bottom: 12px;
}
.meta-item { display: flex; flex-direction: column; gap: 2px; }
.meta-label { font-size: 12px; color: #9CA3AF; }
.meta-value { font-size: 14px; font-weight: 500; color: #1F2937; }

.detail-owner {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
  border-top: 1px solid #EDEDED;
  border-bottom: 1px solid #EDEDED;
  margin-bottom: 12px;
}
.owner-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #1A6EFF;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  flex-shrink: 0;
}
.owner-info { flex: 1; }
.owner-name { font-size: 15px; font-weight: 600; display: block; color: #1F2937; }
.owner-community { font-size: 13px; color: #6B7280; display: block; }

.detail-desc {
  font-size: 14px;
  line-height: 1.7;
  color: #6B7280;
  display: block;
}

.detail-actions { display: flex; flex-direction: column; gap: 10px; padding-bottom: 20px; }
.action-btn {
  width: 100%;
  height: 46px;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
.action-btn.primary { background: #1A6EFF; color: white; }
.action-btn.secondary { background: white; color: #1F2937; border: 2px solid #EDEDED; }
.action-btn.disabled { background: #9CA3AF; color: white; }
.action-btn::after { border: none; }
