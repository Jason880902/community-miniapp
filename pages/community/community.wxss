.page {
  min-height: 100vh;
  background: #F5F6FA;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow-x: hidden;
}
.page-inner {
  width: 100%;
  max-width: 430px;
  flex: 1;
  padding-bottom: 70px;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ===== 头部（与首页一致） ===== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px 10px;
  background: white;
  border-bottom: 1px solid #EDEDED;
}
.header-left { display: flex; flex-direction: column; }
.header-title { font-size: 24px; font-weight: 700; color: #1A6EFF; letter-spacing: -0.5px; }
.header-location { font-size: 12px; color: #6B7280; margin-top: 2px; }
.header-right { display: flex; align-items: center; gap: 10px; }
.header-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A6EFF, #4F46E5);
  color: white;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.community-banner {
  background: linear-gradient(135deg, #1A6EFF 0%, #6366F1 100%);
  padding: 20px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 12px 12px 0;
  border-radius: var(--radius-card, 16px) var(--radius-card, 16px) 0 0;
  box-shadow: 0 4px 16px rgba(26,110,255,0.2);
}
.community-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: rgba(255,255,255,0.13);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.community-icon-img { width: 24px; height: 24px; display: block; }
.community-banner-text { display: flex; flex-direction: column; gap: 2px; }
.community-name { font-size: 18px; font-weight: 700; color: white; letter-spacing: 0.5px; }
.community-subtitle { font-size: 13px; color: rgba(255,255,255,0.6); margin-top: 4px; }

.stats-row {
  display: flex;
  background: white;
  height: 72px;
  margin: 0 12px 14px;
  border-radius: 0 0 var(--radius-card, 16px) var(--radius-card, 16px);
  box-shadow: 0 6px 16px rgba(26,110,255,0.08);
}
.stat-item { flex: 1; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; border-right: 1px solid #F3F4F6; }
.stat-item:last-child { border-right: none; }
.stat-num { font-size: 22px; font-weight: 700; color: #1A6EFF; display: block; line-height: 1; }
.stat-label { font-size: 12px; color: #6B7280; display: block; margin-top: 4px; }

.section {
  background: white;
  margin: 0 12px;
  padding: 16px 20px 8px;
  border-top-left-radius: var(--radius-card, 16px);
  border-top-right-radius: var(--radius-card, 16px);
  box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.04));
}
.section-title { font-size: 15px; font-weight: 600; color: #1F2937; }

.member-list { background: white; padding: 0 20px; border-bottom-left-radius: var(--radius-card, 16px); border-bottom-right-radius: var(--radius-card, 16px); margin: 0 12px 12px; box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.04)); }
.member-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 0;
  border-bottom: 1px solid #F9FAFB;
}
.member-item:last-child { border-bottom: none; }
.member-avatar {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  background: linear-gradient(135deg, #22D3EE, #1A6EFF);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 2px 6px rgba(34,211,238,0.25);
}
.member-info { flex: 1; }
.member-name { font-size: 15px; font-weight: 600; color: #1F2937; display: block; }
.member-community { font-size: 12px; color: #9CA3AF; margin-top: 2px; display: block; }

.empty-hint { padding: 24px 0; text-align: center; color: #9CA3AF; font-size: 14px; }

/* Tab Bar 见 app.wxss（Flutter pill 设计） */