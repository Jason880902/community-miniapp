.page {
  min-height: 100vh;
  background: #EDF4FF;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.page-inner {
  width: 100%;
  max-width: 430px;
  flex: 1;
  padding-bottom: 70px;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 16px;
  background: white;
}
.nav-title { font-size: 17px; font-weight: 600; }

.community-banner {
  background: linear-gradient(135deg, #1A6EFF 0%, #4F46E5 100%);
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.community-icon { font-size: 40px; margin-bottom: 8px; }
.community-name { font-size: 22px; font-weight: 700; color: white; }

.stats-row {
  display: flex;
  background: white;
  padding: 16px 0;
  margin-bottom: 12px;
}
.stat-item { flex: 1; text-align: center; border-right: 1px solid #EDEDED; }
.stat-item:last-child { border-right: none; }
.stat-num { font-size: 22px; font-weight: 700; color: #1A6EFF; display: block; }
.stat-label { font-size: 12px; color: #6B7280; display: block; margin-top: 2px; }

.section {
  background: white;
  padding: 14px 20px 6px;
  margin-bottom: 1px;
}
.section-title { font-size: 15px; font-weight: 600; color: #1F2937; }

.member-list { background: white; padding: 0 20px; }
.member-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 0;
  border-bottom: 1px solid #F3F4F6;
}
.member-item:last-child { border-bottom: none; }
.member-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #22D3EE;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 600;
  flex-shrink: 0;
}
.member-info { flex: 1; }
.member-name { font-size: 15px; font-weight: 600; color: #1F2937; display: block; }
.member-community { font-size: 12px; color: #9CA3AF; margin-top: 2px; display: block; }

.empty-hint { padding: 20px 0; text-align: center; color: #9CA3AF; font-size: 14px; }

/* ===== 底部标签栏 ===== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  background: white;
  border-top: 1px solid #EDEDED;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-inner {
  width: 100%;
  max-width: 430px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: 2px;
  padding: 0 8px;
  box-sizing: border-box;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9CA3AF;
  position: relative;
  height: 50px;
  border-radius: 12px;
  gap: 1px;
  transition: all 0.2s;
}
.tab-item.active {
  color: white;
  background: #1A6EFF;
}
.tab-post {
  background: #1A6EFF;
  color: white;
}
.tab-item.active .tab-icon,
.tab-post .tab-icon { color: white; }
.tab-icon { font-size: 16px; line-height: 1.2; }
.tab-label { font-size: 10px; font-weight: 500; line-height: 1.2; }
.tab-badge {
  position: absolute;
  top: 0;
  right: 50%;
  margin-right: -20px;
  background: #EF4444;
  color: white;
  font-size: 8px;
  padding: 1px 4px;
  border-radius: 8px;
  min-width: 14px;
  text-align: center;
  line-height: 1.2;
}
